#! /usr/bin/env bash
# Doxyfile.in - PROFESSIONALNA DOKUMENTACJA C/C++ PROJECT
# HTML + PDF + DIAGRAMY + ŹRÓDŁA INLINE + SEARCH
# Kompatybilny Doxygen 1.9.8+

# ==================================================
# PROJEKT & METADANE
# ==================================================
PROJECT_NAME           = "Audio Driver MCP4011 + MCP3564"
PROJECT_NUMBER         = "1.0"
PROJECT_BRIEF          = "8x Digital Potentiometers + 8ch ADC + SHM Ring Buffer"
PROJECT_LOGO           = 

# ==================================================
# ŚCIEŻKI - Z KATALOGU BUILD/
# ==================================================
INPUT                  = ../src/ ../include/ ../main.c ../tests/
INPUT_ENCODING         = UTF-8
INPUT_FILTER           = 
FILE_PATTERNS          = *.c *.h *.cpp *.hpp *.md *.txt
RECURSIVE              = YES
EXCLUDE                = ../build/* ../docs/* *.o *.a *.so
EXCLUDE_SYMLINKS       = YES
EXCLUDE_PATTERNS       = 

# ==================================================
# PEŁNA EKSTRACJA - DOKUMENTUJ WSZYSTKO
# ==================================================
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_PACKAGE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES
EXTRACT_ANON_TYPES     = NO
SHOW_INCLUDE_FILES     = YES
SHOW_GROUPED_MEMB_INC  = YES
FORCE_LOCAL_INCLUDES   = NO
SHOW_USED_FILES        = YES
SHOW_DIRECTORIES       = YES
DIAG_SORTED_BY_SCOPE   = NO

# ==================================================
# HTML - GŁÓWNY WYNIK
# ==================================================
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_HEADER            = 
HTML_FOOTER            = 
HTML_STYLESHEET        = 
HTML_EXTRA_STYLESHEET  = 
HTML_EXTRA_FILES       = 
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
HTML_TIMESTAMP         = NO
HTML_DYNAMIC_SECTIONS  = YES
HTML_DYNAMIC_MENUS     = YES
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 250
EXT_LINKS_IN_WINDOW    = NO
FORMULA_FONTSIZE       = 10
FORMULA_TRANSPARENT    = YES
USE_MATHJAX            = NO
MATHJAX_FORMAT         = HTML-CSS
MATHJAX_RELPATH        = 
MATHJAX_EXTENSIONS     = 
MATHJAX_CODEFILE       = 
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO
SEARCHENGINE_URL       = 
SEARCHENGINE_PATH      = 
SEARCHENGINE_FILE      = 
USE_EXTERNAL_GROUPS    = YES
EXTERNAL_GROUPS        = 
EXTERNAL_GROUP_ID      = 
GENERATE_DOCSET        = NO
DOCSET_FEEDNAME        = "Doxygen generated docs"
DOCSET_FEEDAUTHOR      = 
DOCSET_FEEDPUBLISHER   = 
DOCSET_BUNDLE_ID       = org.doxygen.Example
DOCSET_PUBLISHER_ID    = org.doxygen
DOCSET_PUBLISHER_NAME  = 
GENERATE_ECLIPSEHELP   = NO
ECLIPSE_DOC_ID         = org.doxygen.Project
DISABLE_INDEX_HOUR     = NO
DISABLE_INDEX_MINUTE   = NO
GENERATE_XML           = NO
XML_OUTPUT             = xml
XML_SCHEMA             = 
XML_DTD                = 
XML_PROGRAMLISTING     = YES
XML_NS_MEMB_FILE_SCOPE = NO

# ==================================================
# LaTeX / PDF
# ==================================================
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
LATEX_BATCHMODE        = NO
LATEX_HIDE_INDICES     = NO
LATEX_SOURCE_CODE      = YES
LATEX_BIB_STYLE        = 
LATEX_TIMESTAMP        = NO
LATEX_CMD_NAME         = pdflatex
MAKEINDEX_CMD_NAME     = makeindex
LATEX_MAKEINDEX_CMD    = makeindex
COMPACT_LATEX          = NO
PAPER_TYPE             = a4
EXTRA_PACKAGES         = 
LATEX_HEADER           = 
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES
LATEX_POST             = 

# ==================================================
# RTF
# ==================================================
GENERATE_RTF           = NO
RTF_OUTPUT             = rtf
COMPACT_RTF            = NO
RTF_HYPERLINKS         = NO
RTF_STYLESHEET_FILE    = 
RTF_EXTENSIONS_FILE    = 
RTFCONV_CMD            = 

# ==================================================
# MAN PAGES
# ==================================================
GENERATE_MAN           = NO
MAN_OUTPUT             = man
MAN_EXTENSION          = .3
MAN_SUBDIR             = 
MAN_LINKS              = NO

# ==================================================
# DIAGRAMY I GRAPHY
# ==================================================
HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
DOT_FONTNAME           = FreeSans
DOT_FONTSIZE           = 10
DOT_FONTPATH           = 
CLASS_DIAGRAMS         = YES
MSCGEN_PROGRAM         = 
DIA_PROGRAM            = 
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = NO
HIDE_IN_BODY_DOCS      = NO
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CALL_GRAPH_MAX_DEPTH   = 50
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
UML_LOOK               = YES
UML_LIMIT_NUM_FIELDS   = 10
TEMPLATE_RELATIONS     = NO
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
DISTRIBUTE_GROUP_DOC   = NO
DIR_RELATION_DEPTH     = 1
DOT_TRANSPARENT        = NO
